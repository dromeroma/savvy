# =============================================================================
# SavvyCore Environment Configuration (all vars prefixed with SAVVY_)
# =============================================================================

# Application
SAVVY_APP_NAME=SavvyCore
SAVVY_APP_VERSION=0.1.0
SAVVY_APP_ENV=dev
SAVVY_LOG_LEVEL=INFO

# Database (PostgreSQL via Supabase)
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SAVVY_DATABASE_URL=postgresql+asyncpg://postgres.cdvwtgfyetonidjfwflt:[YOUR-DB-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Redis
SAVVY_REDIS_URL=redis://localhost:6379/0

# JWT
SAVVY_JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
SAVVY_JWT_ALGORITHM=HS256
SAVVY_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
SAVVY_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
SAVVY_CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]
